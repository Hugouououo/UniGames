func _ready():
	gerar_labirinto_dinamico()

func gerar_labirinto_dinamico():
	clear()
	
	for z in range(mapa_30x30.size()):
		for x in range(mapa_30x30[z].size()):
			var tipo = mapa_30x30[z][x]
			
			# Se o tipo for 0, o código simplesmente pula esta posição, 
			# deixando o buraco para a lava que está embaixo.
			
			if tipo == 1: # Chão Base
				set_cell_item(Vector3i(x, 0, z), 0)
			
			elif tipo == 2: # Chão Médio (Nível 1)
				set_cell_item(Vector3i(x, 0, z), 0)
				set_cell_item(Vector3i(x, 1, z), 0)
				
			elif tipo == 4: # Chão Alto (Nível 2)
				set_cell_item(Vector3i(x, 0, z), 0)
				set_cell_item(Vector3i(x, 1, z), 0)
				set_cell_item(Vector3i(x, 2, z), 0)
				
			elif tipo == 9: # Parede
				for h in range(6): 
					set_cell_item(Vector3i(x, h, z), 0)
